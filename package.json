{
  "name": "agents",
  "version": "0.0.1",
  "description": "A fork of cloudflare/agents — framework for building AI agents on Cloudflare Workers",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --out-dir dist",
    "dev": "tsup src/index.ts --format esm --dts --out-dir dist --watch",
    "test": "vitesttest:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "tsx .github/changeset-version.ts",
    "release": "tsx .github/changeset-publish.ts"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "agents",
    "ai",
    "durable-objects"
  ],
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@cloudflare/workers-types": "^4.20240208.0",
    "@types/node": "^20.11.5",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudflare/agents",
    "fork": true
  }
}
